{
  "name": "sw-architecture-snippets",
  "displayName": "SW Architecture Snippets",
  "publisher": "Snippetor",
  "description": "Extension to manage software architecture snippets with explorer view and snippet capture",
  "version": "0.0.5",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "swArchitectureSnippets",
          "title": "SW Snippets",
          "icon": "out/icon.svg"
        }
      ]
    },
    "views": {
      "swArchitectureSnippets": [
        {
          "type": "webview",
          "id": "snippetExplorerView",
          "name": "Explorer",
          "icon": "/out/extension/media/icon.svg"
        },
        {
          "type": "webview",
          "id": "workingSnippetView",
          "name": "Working Snippet",
          "icon": "/out/extension/media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "swArchitectureSnippets.addSelectionToSnippet",
        "title": "Add Selection to Working Snippet"
      },
      {
        "command": "snippetExplorer.refresh",
        "title": "Refresh Snippets",
        "icon": "$(refresh)"
      },
      {
        "command": "snippetExplorer.open",
        "title": "Open Snippet"
      },
      {
        "command": "snippetExplorer.addSnippet",
        "title": "Add Snippet",
        "icon": "$(new-file)"
      },
      {
        "command": "snippetExplorer.addFolder",
        "title": "Add Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "snippetExplorer.openConfig",
        "title": "Open Config",
        "icon": "$(settings-gear)"
      },
      {
        "command": "workingSnippet.newItem",
        "title": "New Snippet Item",
        "icon": "$(new-file)"
      },
      {
        "command": "workingSnippet.refresh",
        "title": "Refresh Snippet",
        "icon": "$(refresh)"
      },
      {
        "command": "workingSnippet.close",
        "title": "Close Snippet",
        "icon": "$(close)"
      },
      {
        "command": "workingSnippet.showSaveDialog",
        "title": "Save Snippet",
        "icon": "$(save)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "snippetExplorer.open",
          "when": "view == snippetExplorerView",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "snippetExplorer.refresh",
          "when": "view == snippetExplorerView",
          "group": "navigation"
        },
        {
          "command": "snippetExplorer.openConfig",
          "when": "view == snippetExplorerView",
          "group": "navigation"
        },
        {
          "command": "snippetExplorer.addSnippet",
          "when": "view == snippetExplorerView",
          "group": "navigation"
        },
        {
          "command": "snippetExplorer.addFolder",
          "when": "view == snippetExplorerView",
          "group": "navigation"
        },
        {
          "command": "workingSnippet.close",
          "when": "view == workingSnippetView",
          "group": "navigation"
        },
        {
          "command": "workingSnippet.refresh",
          "when": "view == workingSnippetView",
          "group": "navigation"
        },
        {
          "command": "workingSnippet.newItem",
          "when": "view == workingSnippetView",
          "group": "navigation"
        },
        {
          "command": "workingSnippet.showSaveDialog",
          "when": "view == workingSnippetView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build:explorer": "node scripts/build-explorer-view.js",
    "build:test-page": "node scripts/build-test-page.js",
    "build:bundle": "node scripts/build-bundle.js",
    "compile": "npm run build:explorer && npm run build:bundle",
    "compile:test": "tsc -p ./tsconfig.test.json && npm run build:test-page",
    "compile:vscode-test": "tsc -p ./tsconfig.vscode-test.json",
    "test-host": "vitest run",
    "test:vscode": "npm run compile && npm run compile:vscode-test && vscode-test",
    "vscode:prepublish": "npm run compile"
  },
  "files": [
    "out",
    "media"
  ],
  "resources": [
    "out/extension/media/snippetView.html",
    "out/extension/media/explorerView.html",
    "out/extension/media/icon.svg",
    "out/icon.svg",
    "media/icon.svg",
    "out/extension/media/images/light_empty.png",
    "out/extension/media/images/light_error.png",
    "out/extension/media/images/light_plus.png"
  ],
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
